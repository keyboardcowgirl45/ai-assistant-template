# ===== REQUIRED =====

# Discord Bot Token
# Get this from https://discord.com/developers/applications
# Create a new application → Bot → Copy token
DISCORD_TOKEN=your_discord_bot_token_here

# Your Bot's Display Name (must match what you set in Discord developer portal)
BOT_NAME=YourBotName

# Your Discord User ID (right-click your name in Discord → Copy User ID)
# This tells the bot who the "owner" is — it only responds to this user
KS_DISCORD_ID=your_discord_user_id_here

# Your Name (used in prompts — the bot will address you by this name)
# IMPORTANT: After cloning, also search-and-replace "KS" in the .js files
# with your name/nickname. See SETUP-GUIDE.md Step 5 for details.
OWNER_NAME=YourName

# ===== RECOMMENDED — Gemini Fallback =====

# Google Gemini API Key (for fallback when Claude is down + image generation)
# Claude has occasional outages. Without this, your bot goes completely silent.
# Get a FREE key at https://aistudio.google.com/apikey (takes 30 seconds)
GEMINI_API_KEY=

# ===== OPTIONAL — Enable as needed =====

# Brave Search API Key (for web search)
# Get a free key at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Oura Ring API Token (for sleep/health data)
# Get this from https://cloud.ouraring.com/personal-access-tokens
OURA_API_TOKEN=

# Gmail SMTP (for sending emails from the bot)
# Use an App Password, NOT your regular Gmail password
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Granola API Key (for meeting notes — optional, can also use MCP)
GRANOLA_API_KEY=
